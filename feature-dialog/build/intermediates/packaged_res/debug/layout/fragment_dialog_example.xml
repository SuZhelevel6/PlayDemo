<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:paddingBottom="250dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="💬 空祖家的DialogX对话框组件库，实现了Material、iOS、MIUI等主题扩展，对话框和各种组件十分美观"
                android:textColor="#DC373737"
                android:textSize="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="选择风格"
                android:textColor="#dc000000"
                android:textSize="14dp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/styleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMaterial"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Material" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="iOS" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKongzue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kongzue" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMiui"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MIUI" />
            </com.google.android.material.button.MaterialButtonToggleGroup>


            <TextView
                android:id="@+id/txtStyleInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="对话框"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowMessageDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="消息对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="选择对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInputDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="输入对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelectMessageMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="单选菜单对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMutiSelectMessageMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="多选菜单对话框" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="阻断提示"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWaitDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWaitAndTipDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待+提示对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTipDialogSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="完成" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTipDialogWaring"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="警告" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTipDialogError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="错误" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTipProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="进度提示" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="非阻断提示"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoptip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="基本提示" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoptipBigMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="长文本提示" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoptipSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="成功提示" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoptipWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="警告提示" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPoptipError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="错误提示" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="底部菜单"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBottomDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="底部对话框" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBottomMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="底部菜单" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBottomSelectMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="底部单选菜单" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBottomMultiSelectMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="底部多选菜单" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBottomCustomRecycleView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="底部自定义滑动布局 RecycleView" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="全屏对话框"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFullScreenDialogWebPage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示网页" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="上下文菜单"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContextMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="基础上下文菜单" />

                <TextView
                    android:id="@+id/btnSelectMenu"
                    android:layout_width="160dp"
                    android:layout_height="48dp"
                    android:layout_margin="5dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/rect_dialogx_material_poptip_bkg"
                    android:drawableRight="@mipmap/img_drawable_down"
                    android:gravity="center_vertical"
                    android:paddingLeft="15dp"
                    android:paddingRight="5dp"
                    android:singleLine="true"
                    android:text="选项菜单"
                    android:textColor="@color/black"
                    android:textSize="16dp" />

            </com.kongzue.stacklabelview.StackLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="引导提示"
                android:textSize="14sp" />

            <com.kongzue.stacklabelview.StackLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowGuide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="普通引导" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowGuideBaseView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="指定引导" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowGuideBaseViewRectangle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="指定引导[矩形]" />

            </com.kongzue.stacklabelview.StackLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>